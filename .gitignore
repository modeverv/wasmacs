# OS / editor noise
.DS_Store
._*
*.swp
*.swo
*~
\#*\#
.\#*

# Local environment
.env
.env.*
!.env.example
.direnv/
.mise.local.toml

# Logs
logs/*
!logs/.gitkeep
!logs/*.txt
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Build and generated artifacts
build/
dist/
out/
tmp/
temp/
cache/
artifacts/

# wasmacs generated images and runtime outputs
*.wasm
*.wasm.map
*.wasifs
*.wasmpack
*.manifest.json
*.journal.jsonl

# Keep interface/design sources trackable if they appear under artifacts by accident.
!docs/**/*.md
!scripts/**/*.sh
!wit/**/*.wit

# JavaScript / TypeScript app tooling
node_modules/
.npm/
.pnpm-store/
.yarn/
!.yarn/patches/
!.yarn/plugins/
!.yarn/releases/
!.yarn/sdks/
!.yarn/versions/
.turbo/
.vite/
.next/
.parcel-cache/
coverage/
playwright-report/
test-results/

# Python helper tooling
.venv/
venv/
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Native compilation byproducts
*.o
*.a
*.so
*.dylib
*.dll
*.exe
*.dSYM/

# Emacs build byproducts outside the vendor submodule
emacs
temacs
bootstrap-emacs
*.elc
auto-autoloads.el
loaddefs.el

# Do not ignore the Emacs source submodule itself.
!vendor/
!vendor/emacs/

.claude

