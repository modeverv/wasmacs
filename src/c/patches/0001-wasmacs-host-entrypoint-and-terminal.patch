+__attribute__ ((used, visibility ("default")))
+int
+wasmacs_os_begin_command (const char *kind)
+{
+  if (wasmacs_command_busy)
+    {
+      wasmacs_store_c_string_result ("unavailable:busy");
+      return 3;
+    }
