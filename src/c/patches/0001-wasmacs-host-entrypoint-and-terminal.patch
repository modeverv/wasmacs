+__attribute__ ((used, visibility ("default")))
+const char *
+wasmacs_os_pending_command_state (void)
+{
+  if (wasmacs_command_busy && minibuf_level > 0)
+    return "pending-input";
+  if (wasmacs_command_busy)
+    return "command-running";
+  return "idle";
+}
