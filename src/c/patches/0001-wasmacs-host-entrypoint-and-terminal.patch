+__attribute__ ((used, visibility ("default")))
+int
+wasmacs_input_text (const char *utf8)
+{
+  if (!utf8)
+    return 2;
+
+  while (*utf8)
+    {
+      unsigned char byte = (unsigned char) *utf8++;
+      if (byte >= 0x80)
+        return 4;
