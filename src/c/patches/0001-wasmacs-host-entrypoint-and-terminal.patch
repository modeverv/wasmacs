+  /* Restore any GC inhibit pushed for the command's pending-input window.  */
+  while (wasmacs_pending_gc_inhibit_depth > 0)
+    {
+      garbage_collection_inhibited--;
+      wasmacs_pending_gc_inhibit_depth--;
+    }
