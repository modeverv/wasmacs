+      struct input_event event;
+      EVENT_INIT (event);
+      event.kind = ASCII_KEYSTROKE_EVENT;
+      event.modifiers = 0;
+      event.code = byte;
+      event.frame_or_window = selected_frame;
+      event.arg = Qnil;
+      event.timestamp = 0;
+      kbd_buffer_store_event (&event);
+    }
+
+  return 0;
+}
 
