+                                                 wasmacs_eval_error_handler);
+  wasmacs_store_result (result);
+  unbind_to (gc_count, Qnil);
+  WASMACS_LEAVE_HOST_ENTRYPOINT (saved_stack_bottom, saved_stack_top);
+  return wasmacs_eval_had_error ? 1 : 0;
+}
